-- Identifying companies that laid off 100% of their staff
SELECT 
    industry, 
    stage,
    COUNT(company) AS total_closures,
    SUM(funds_raised_millions) AS total_funds_lost_millions,
    ROUND(AVG(funds_raised_millions), 2) AS avg_funding_before_failure
FROM layoffs2
WHERE percentage_laid_off = 1 and stage = 'Seed'
GROUP BY industry, stage
HAVING total_funds_lost_millions IS NOT NULL
ORDER BY total_closures DESC;

--Identifying which "Big Players" hit rock bottom
SELECT 
    company, 
    industry, 
    stage, 
    funds_raised_millions,
    `date`
FROM layoffs_staging
WHERE stage IN ('Series E', 'Post-IPO', 'Private Equity', 'Acquired')
  AND percentage_laid_off = 1
ORDER BY funds_raised_millions DESC;

--Do companies that raise more money actually lay off a higher number of people?
SELECT 
    CASE 
        WHEN funds_raised_millions < 50 THEN 'Low Funding (<50M)'
        WHEN funds_raised_millions BETWEEN 50 AND 500 THEN 'Medium Funding (50-500M)'
        WHEN funds_raised_millions > 500 THEN 'High Funding (>500M)'
        ELSE 'Unknown'
    END AS funding_tier,
    COUNT(company) AS count_of_companies,
    AVG(percentage_laid_off) AS avg_layoff_percentage,
    SUM(total_laid_off) AS total_employees_impacted
FROM layoffs_staging
WHERE total_laid_off IS NOT NULL
GROUP BY funding_tier
ORDER BY total_employees_impacted DESC;

--when the big layoff happened.
SELECT 
    YEAR(`date`) AS layoff_year, 
    MONTH(`date`) AS layoff_month, 
    SUM(total_laid_off) AS monthly_total
FROM layoffs_staging
WHERE total_laid_off IS NOT NULL
  AND date IS NOT NULL  
GROUP BY layoff_year, layoff_month
ORDER BY layoff_year DESC, layoff_month DESC
