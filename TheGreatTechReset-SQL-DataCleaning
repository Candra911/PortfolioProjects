WHERE
    total_laid_off IS NULL
    AND percentage_laid_off IS NULL;

-- 25. Preview conversion of date strings to proper DATE type
SELECT
    `date`,
    STR_TO_DATE(`date`, '%m/%d/%Y') AS converted_date
FROM
    layoffs_staging;

-- 26. Apply the date conversion
UPDATE layoffs_staging
SET
    `date` = STR_TO_DATE(`date`, '%m/%d/%Y');

-- 27. Drop the temporary row number column
ALTER TABLE layoffs_staging
DROP COLUMN row_num;

-- 28. Change the data type of the date column to DATE
ALTER TABLE layoffs_staging
MODIFY COLUMN `date` DATE;

-- 29. Final check for any null dates (should be none after conversion)
SELECT *
FROM
    layoffs_staging
WHERE
    `date` IS NULL;
