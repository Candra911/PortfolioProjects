-- 23. Identify rows missing both total_laid_off and percentage_laid_off
SELECT *
FROM
    layoffs_staging
WHERE
    total_laid_off IS NULL
    AND percentage_laid_off IS NULL;

-- 24. Delete those useless rows (cannot be used for analysis)
